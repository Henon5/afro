PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# MongoDB Atlas Connection String (REQUIRED for Railway deployment)
# Get this from https://mongodb.com/cloud/atlas
# Format: mongodb+srv://<username>:<password>@cluster.mongodb.net/<database>?retryWrites=true&w=majority
# SECURITY: Use environment variables or secrets management in production - NEVER commit real credentials
MONGODB_URI=${MONGODB_URI_FROM_SECRETS_MANAGER}

# Telegram Bot Token (REQUIRED for authentication)
# Get from @BotFather on Telegram
# SECURITY: Use environment variables or secrets management in production
TELEGRAM_BOT_TOKEN=${TELEGRAM_BOT_TOKEN_FROM_SECRETS_MANAGER}

# SECURITY: Use a strong, randomly generated JWT secret (min 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=${GENERATE_STRONG_RANDOM_SECRET_IN_PRODUCTION}
JWT_EXPIRE=7d

# SECURITY: Change these default admin credentials immediately
# Use strong, randomly generated values
ADMIN_MASTER_ID=${CHANGE_THIS_DEFAULT_ADMIN_ID}
ADMIN_SECURE_CODE=${GENERATE_RANDOM_SECURE_CODE}
ADMIN_SECURITY_KEY=${GENERATE_RANDOM_SECURITY_KEY}

HOUSE_COMMISSION=0.15
MIN_DEPOSIT=20
MIN_WITHDRAWAL=10
MAX_WITHDRAWAL=5000

RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100
