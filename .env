PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# MongoDB Atlas Connection String
# For local development with MongoDB installed locally:
# MONGODB_URI=mongodb://localhost:27017/afro-bingo?retryWrites=true&w=majority
# For MongoDB Atlas (replace with your actual credentials):
MONGODB_URI=mongodb+srv://testuser:testpass@cluster0.mongodb.net/afro-bingo?retryWrites=true&w=majority&ssl=true

# Telegram Bot Token (Get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# JWT Secret - Generate a random string for production
JWT_SECRET=afro-bingo-jwt-secret-key-change-in-production-12345678
JWT_EXPIRE=7d

# Admin Security - Change these in production
ADMIN_MASTER_ID=MasterAdmin
ADMIN_SECURE_CODE=SECURE123
ADMIN_SECURITY_KEY=GOLDENKEY

# Additional admin token header
ADMIN_SECRET_KEY=ADMIN_SECRET_TOKEN_CHANGE_IN_PRODUCTION

HOUSE_COMMISSION=0.15
MIN_DEPOSIT=20
MIN_WITHDRAWAL=10
MAX_WITHDRAWAL=5000

RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100
